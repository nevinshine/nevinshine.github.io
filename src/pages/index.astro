---
import BaseHead from '../components/BaseHead.astro';
import ProjectCard from '../components/projects/ProjectCard.astro';

const base = '/';
const dossierLink = "https://nevinshine.github.io/system-security-research-dossier/";
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead title="Nevin Shine | Undergraduate Systems Researcher" description="Linux Runtime Defense, eBPF & AI Safety" />
    </head>
    <body class="bg-[#050505] text-gray-300 font-sans min-h-screen flex justify-center selection:bg-green-900 selection:text-white">
        <div class="w-full max-w-4xl px-6 py-16">

            <div class="flex justify-between items-center text-[10px] font-mono text-neutral-600 mb-12 tracking-widest uppercase">
                <span>Nürnberg (DE) // Kottayam (IN)</span>
                <span class="flex items-center gap-2">
                    <span class="w-1.5 h-1.5 bg-green-500 rounded-full animate-pulse"></span>
                    System Online
                </span>
            </div>

            <header class="mb-16 flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
                <div>
                    <h1 class="text-5xl md:text-6xl font-bold text-white tracking-tighter mb-4">Nevin Shine</h1>
                    <p class="text-xl text-neutral-400 font-light max-w-lg leading-relaxed">
                        Undergraduate Systems Security Researcher <span class="text-neutral-700 mx-2">/</span> Kernel Defense
                    </p>
                    <p class="text-sm text-neutral-500 mt-2 font-mono">Focus: eBPF, Runtime Enforcement & AI Safety</p>
                </div>

                <div class="flex flex-col sm:flex-row gap-3">
                    <a href={dossierLink} target="_blank" class="group flex items-center gap-3 px-5 py-3 border border-neutral-800 hover:border-green-500 transition-colors duration-300 bg-neutral-900/50 rounded-sm no-underline">
                        <div class="text-left">
                            <span class="block text-[10px] text-neutral-500 uppercase tracking-wider group-hover:text-green-500/70">External Archive — Milestone M5.0</span>
                            <span class="block text-sm font-bold text-gray-200 group-hover:text-green-400">View Research Dossier</span>
                        </div>
                    </a>
                    
                    <a href="/nevinshinecv.pdf" download class="group flex items-center gap-3 px-5 py-3 border border-neutral-800 hover:border-green-500 transition-colors bg-neutral-900/50 rounded-sm no-underline">
                        <div class="text-left text-neutral-500 group-hover:text-green-500">
                            <span class="block text-[10px] uppercase tracking-wider">Reference</span>
                            <span class="block text-sm font-bold text-gray-200 group-hover:text-green-400">Download CV</span>
                        </div>
                    </a>
                </div>
            </header>

            <div class="mb-20 grid grid-cols-2 md:grid-cols-4 gap-px bg-neutral-900 border border-neutral-900">
                <div class="bg-[#050505] p-4">
                    <span class="block text-[10px] text-neutral-600 mb-1">CORE</span>
                    <span class="text-sm text-gray-300 font-mono">Linux / C / eBPF</span>
                </div>
                <div class="bg-[#050505] p-4">
                    <span class="block text-[10px] text-neutral-600 mb-1 font-bold">ANALYSIS</span>
                    <span class="text-sm text-gray-300 font-mono">Python / WiSARD</span>
                </div>
                <div class="bg-[#050505] p-4">
                    <span class="block text-[10px] text-neutral-600 mb-1 font-bold font-mono">ARCHITECTURE</span>
                    <span class="text-sm text-gray-300 font-mono">TELOS Runtime</span>
                </div>
                <div class="bg-[#050505] p-4">
                    <span class="block text-[10px] text-neutral-600 mb-1">STATUS</span>
                    <span class="text-sm text-gray-300 font-mono">Active Defense Online</span>
                </div>
            </div>

            <section class="mb-24">
                <h2 class="text-xs font-bold text-green-500 mb-8 flex items-center tracking-widest uppercase">// Research Tracks <span class="ml-4 h-px bg-neutral-800 flex-grow"></span></h2>
                
                <div class="mb-8 p-6 border border-neutral-800 bg-neutral-900/30">
                    <h3 class="text-lg font-bold text-white mb-2 font-mono">TELOS: Agentic Security Runtime</h3>
                    <p class="text-sm text-neutral-400 leading-relaxed">
                        A split-plane defense architecture preventing Indirect Prompt Injection and Data Exfiltration in Autonomous AI Agents.
                        It bridges the "Semantic Gap" by verifying high-level intent (Cortex) and enforcing it via Kernel (Core) and Network (Edge) boundaries.
                    </p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    
                   <ProjectCard 
                        title="Sentinel (TELOS Core)" 
                        description="M3.4 Active. The Kernel-Level Bodyguard. Detects and blocks malicious syscalls (execve, open) using ptrace/LSM hooks to prevent unauthorized execution by compromised agents." 
                        tags={['C', 'LSM Hooks', 'ptrace', 'Host Defense']} 
                        link="https://github.com/nevinshine/sentinel-runtime" 
                        status="M3.4 Stable" 
                    />

                    <ProjectCard 
                        title="Hyperion (TELOS Edge)" 
                        description="M4.6 Active. The Network Border Patrol. A high-speed eBPF/XDP firewall that drops malicious packets at the NIC (O(1)) before they touch the OS stack." 
                        tags={['eBPF', 'XDP', 'Go', 'Network Defense']} 
                        link="https://github.com/nevinshine/hyperion-xdp" 
                        status="M4.6 Stable" 
                    />
                    
                </div>
            </section>

            <footer class="mt-20 pt-10 pb-12 border-t border-neutral-800 text-center bg-transparent">
                <div class="mb-10 flex justify-center items-center gap-4">
                    <span class="h-px w-12 bg-neutral-900"></span>
                    <span class="text-[10px] font-mono text-green-500 uppercase tracking-widest font-bold">End of Transmission</span>
                    <span class="h-px w-12 bg-neutral-900"></span>
                </div>
                <div class="flex justify-center flex-wrap gap-10 mb-10">
                    <a href="https://github.com/nevinshine" target="_blank" class="text-[11px] font-mono text-white hover:text-green-400 uppercase tracking-widest no-underline font-bold">[ GITHUB ]</a>
                    <a href="https://linkedin.com/in/nevin-shine-b403b932b" target="_blank" class="text-[11px] font-mono text-white hover:text-green-400 uppercase tracking-widest no-underline font-bold">[ LINKEDIN ]</a>
                    <a href="mailto:nevinshine05@outlook.com" class="text-[11px] font-mono text-white hover:text-green-400 uppercase tracking-widest no-underline font-bold">[ EMAIL ]</a>
                </div>
                <div class="text-[10px] text-neutral-500 font-mono space-y-2 uppercase tracking-widest">
                    <p>INITIATED AT NEVIN-LAB // NÜRNBERG, DE</p>
                    <p class="text-neutral-600">© 2026 NEVIN SHINE // SYSTEM SECURE</p>
                </div>
            </footer>
        </div>
    </body>
</html>

